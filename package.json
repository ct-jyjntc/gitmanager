{
  "name": "gitm-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "dev:electron": "electron .",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://127.0.0.1:5173 http://127.0.0.1:3001/api/health && npm run dev:electron\"",
    "build:web": "npm run build --prefix client",
    "build:desktop": "npm run build:web && electron-builder --win nsis",
    "dist": "npm run build:desktop"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.gitm.desktop",
    "productName": "GitM",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "build/**/*",
      "client/dist/**/*",
      "server/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
